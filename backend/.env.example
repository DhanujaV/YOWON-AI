# Ollama — must match `ollama list` on your machine
OLLAMA_HOST=http://localhost:11434
OLLAMA_SPECIALIST_MODEL=qwen2.5:7b
OLLAMA_CHIEF_MODEL=qwen3:8b
OLLAMA_FAST_MODEL=qwen2.5:7b
OLLAMA_FALLBACK_MODEL=qwen2.5:3b
OLLAMA_PARALLEL=2

# Context window & generation
OLLAMA_NUM_CTX=8192
OLLAMA_SPECIALIST_NUM_PREDICT=200
OLLAMA_CHIEF_NUM_PREDICT=300
OLLAMA_TEMPERATURE=0.1

# CrewAI agent limits (single pass, up to 10 min per agent)
AGENT_MAX_ITER=1
AGENT_MAX_EXECUTION_TIME=600
CHIEF_MAX_EXECUTION_TIME=600
AGENT_TIMEOUT_SEC=600
EVALUATION_TIMEOUT_SEC=3600

# Prompt size caps
MAX_CONTEXT_CHARS=6000
MAX_BRIEF_CHARS=1200
MAX_AGENT_DIGEST_CHARS=2500

# Direct Ollama (recommended) — bypasses CrewAI iteration loop
USE_DIRECT_LLM_PRIMARY=true

# Retries & failure score
AGENT_MAX_RETRIES=2
FAILED_AGENT_SCORE=35

# Optional
GITHUB_TOKEN=
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO
